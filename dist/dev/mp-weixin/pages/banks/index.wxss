/* uni-app 全局 SCSS 变量 */
.container.data-v-f1e3db7f {
  padding: 24rpx;
  padding-bottom: 160rpx;
}
.page-header.data-v-f1e3db7f {
  padding: 32rpx 0;
  text-align: center;
}
.app-name.data-v-f1e3db7f {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.slogan.data-v-f1e3db7f {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* 骨架屏 */
.skeleton-card.data-v-f1e3db7f {
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
}
.sk-icon.data-v-f1e3db7f {
  width: 64rpx;
  height: 64rpx;
  background: #e0e0e0;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.sk-line.data-v-f1e3db7f {
  height: 24rpx;
  background: #e0e0e0;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
}
.sk-title.data-v-f1e3db7f {
  width: 60%;
}
.sk-desc.data-v-f1e3db7f {
  width: 90%;
}

/* 错误状态 */
.error-state.data-v-f1e3db7f {
  text-align: center;
  padding: 120rpx 48rpx;
}
.error-icon.data-v-f1e3db7f {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}
.error-text.data-v-f1e3db7f {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}
.retry-btn.data-v-f1e3db7f {
  background: var(--color-primary);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 16rpx 64rpx;
}

/* 题库卡片 */
.bank-card.data-v-f1e3db7f {
  padding: 32rpx;
  margin-bottom: 24rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}
.bank-card.data-v-f1e3db7f:active {
  transform: scale(0.98);
}
.bank-card.disabled.data-v-f1e3db7f {
  opacity: 0.5;
}
.card-header.data-v-f1e3db7f {
  display: flex;
  align-items: center;
}
.bank-icon.data-v-f1e3db7f {
  font-size: 48rpx;
  margin-right: 20rpx;
}
.card-info.data-v-f1e3db7f {
  flex: 1;
}
.bank-name.data-v-f1e3db7f {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.bank-count.data-v-f1e3db7f {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}
.arrow.data-v-f1e3db7f {
  font-size: 36rpx;
  color: var(--text-hint);
}
.bank-desc.data-v-f1e3db7f {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

/* 进度条 */
.progress-bar.data-v-f1e3db7f {
  height: 8rpx;
  background: #e8e8e8;
  border-radius: 4rpx;
  margin-top: 20rpx;
  overflow: hidden;
}
.progress-fill.data-v-f1e3db7f {
  height: 100%;
  background: var(--color-primary);
  border-radius: 4rpx;
  transition: width 0.5s;
}
.progress-text.data-v-f1e3db7f {
  display: block;
  font-size: 22rpx;
  color: var(--color-primary);
  margin-top: 8rpx;
}

/* 广告 */
.ad-placeholder.data-v-f1e3db7f {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: var(--bg-card);
  text-align: center;
  line-height: 100rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}