<view class="container data-v-f1e3db7f"><view class="page-header data-v-f1e3db7f"><text class="app-name data-v-f1e3db7f">WorkQuery</text><text class="slogan data-v-f1e3db7f">刷题巩固，即查即用</text></view><view wx:if="{{a}}" class="skeleton-list data-v-f1e3db7f"><view wx:for="{{b}}" wx:for-item="i" wx:key="a" class="skeleton-card data-v-f1e3db7f"><view class="sk-icon data-v-f1e3db7f"></view><view class="sk-line sk-title data-v-f1e3db7f"></view><view class="sk-line sk-desc data-v-f1e3db7f"></view></view></view><view wx:elif="{{c}}" class="error-state data-v-f1e3db7f"><text class="error-icon data-v-f1e3db7f">😵</text><text class="error-text data-v-f1e3db7f">{{d}}</text><button class="retry-btn data-v-f1e3db7f" bindtap="{{e}}">点击重试</button></view><view wx:else class="bank-list data-v-f1e3db7f"><view wx:for="{{f}}" wx:for-item="bank" wx:key="j" class="{{['bank-card', 'data-v-f1e3db7f', bank.k && 'disabled']}}" bindtap="{{bank.l}}"><view class="card-header data-v-f1e3db7f"><text class="bank-icon data-v-f1e3db7f">{{bank.a}}</text><view class="card-info data-v-f1e3db7f"><text class="bank-name data-v-f1e3db7f">{{bank.b}}</text><text class="bank-count data-v-f1e3db7f">共 {{bank.c}} 题</text></view><text class="arrow data-v-f1e3db7f">›</text></view><text class="bank-desc data-v-f1e3db7f">{{bank.d}}</text><view wx:if="{{bank.e}}" class="progress-bar data-v-f1e3db7f"><view class="progress-fill data-v-f1e3db7f" style="{{'width:' + bank.f}}"></view></view><text wx:if="{{bank.g}}" class="progress-text data-v-f1e3db7f"> 已完成 {{bank.h}}/{{bank.i}} 题 </text></view></view><view wx:if="{{g}}" class="ad-placeholder data-v-f1e3db7f">广告位</view></view>