/* uni-app 全局 SCSS 变量 */
.container.data-v-39c3016b {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-primary);
}
.container page.data-v-39c3016b {
  height: 100%;
}

/* 顶部栏 */
.top-bar.data-v-39c3016b {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border-color);
  flex-shrink: 0;
}
.q-progress.data-v-39c3016b {
  font-size: 28rpx;
  color: var(--text-secondary);
}
.fav-icon.data-v-39c3016b {
  font-size: 44rpx;
  color: var(--color-warning);
  padding: 8rpx;
}

/* 滑动区域 */
.q-swiper.data-v-39c3016b {
  flex: 1;
  height: 0;
  min-height: 0;
}
.q-scroll.data-v-39c3016b {
  box-sizing: border-box;
  padding: 32rpx;
  padding-bottom: 60rpx;
}

/* 题干 */
.q-body.data-v-39c3016b {
  margin-bottom: 24rpx;
}
.q-text.data-v-39c3016b {
  font-size: 32rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

/* 代码块 */
.code-block.data-v-39c3016b {
  margin: 16rpx 0;
  background: #1e1e1e;
  border-radius: 12rpx;
  overflow: hidden;
}
.code-header.data-v-39c3016b {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 20rpx;
  background: #333;
}
.code-lang.data-v-39c3016b {
  font-size: 22rpx;
  color: #aaa;
  text-transform: uppercase;
}
.code-copy.data-v-39c3016b {
  font-size: 22rpx;
  color: #6cf;
}
.code-content.data-v-39c3016b {
  padding: 12rpx 20rpx 16rpx;
  font-size: 24rpx;
  color: #d4d4d4;
}

/* 选项 */
.options.data-v-39c3016b {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 24rpx 0;
}
.opt-item.data-v-39c3016b {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 14rpx;
  background: var(--bg-card);
  transition: all 0.25s ease;
}
.opt-letter.data-v-39c3016b {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-hint);
  margin-right: 16rpx;
  min-width: 40rpx;
}
.opt-text.data-v-39c3016b {
  font-size: 30rpx;
  color: var(--text-primary);
  flex: 1;
}
.opt-item.correct.data-v-39c3016b {
  background: #e6f9f0;
  border-color: var(--color-success);
}
.opt-item.correct .opt-text.data-v-39c3016b, .opt-item.correct .opt-letter.data-v-39c3016b {
  color: #0a8a3a;
}
.opt-item.wrong.data-v-39c3016b {
  background: #fff0f0;
  border-color: var(--color-danger);
}
.opt-item.wrong .opt-text.data-v-39c3016b, .opt-item.wrong .opt-letter.data-v-39c3016b {
  color: #d32f2f;
}
.opt-item.locked.data-v-39c3016b {
  opacity: 0.45;
  pointer-events: none;
}

/* 解析 */
.explanation.data-v-39c3016b {
  margin-top: 28rpx;
  padding: 28rpx;
  background: var(--bg-card);
  border-radius: 14rpx;
  border-left: 6rpx solid var(--color-primary);
  animation: slideIn-39c3016b 0.3s ease;
}
@keyframes slideIn-39c3016b {
from {
    opacity: 0;
    transform: translateY(-16rpx);
}
to {
    opacity: 1;
    transform: translateY(0);
}
}
.exp-header.data-v-39c3016b {
  margin-bottom: 12rpx;
}
.exp-tag.data-v-39c3016b {
  font-size: 26rpx;
  font-weight: 600;
}
.explanation .correct .exp-tag.data-v-39c3016b {
  color: var(--color-success);
}
.exp-text.data-v-39c3016b {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}
.exp-code.data-v-39c3016b {
  margin-top: 16rpx;
}
.knowledge-tags.data-v-39c3016b {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.ktag.data-v-39c3016b {
  font-size: 24rpx;
  color: var(--color-primary);
  background: #e8f4fd;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 底部操作栏 */
.bottom-bar.data-v-39c3016b {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-color);
}
.bn-btn.data-v-39c3016b {
  min-width: 180rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  border-radius: 38rpx;
  border: none;
  background: var(--color-primary);
  color: #fff;
  text-align: center;
}
.bn-btn.prev.data-v-39c3016b {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}
.bn-btn[disabled].data-v-39c3016b {
  opacity: 0.35;
}
.bn-indicator.data-v-39c3016b {
  font-size: 26rpx;
  color: var(--text-hint);
}