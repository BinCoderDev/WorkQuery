/* uni-app 全局 SCSS 变量 */
.container.data-v-f770353a {
  padding: 32rpx;
  padding-bottom: 200rpx;
}
.loading.data-v-f770353a, .error.data-v-f770353a {
  text-align: center;
  padding: 120rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}
.detail-header.data-v-f770353a {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}
.title.data-v-f770353a {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
}
.fav-icon.data-v-f770353a {
  font-size: 44rpx;
  color: var(--color-warning);
  padding: 8rpx;
}
.syntax-box.data-v-f770353a {
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 28rpx;
  border-left: 6rpx solid var(--color-primary);
}
.s-label.data-v-f770353a {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-bottom: 6rpx;
}
.s-code.data-v-f770353a {
  font-size: 26rpx;
  font-family: monospace;
  color: var(--text-primary);
}
.section.data-v-f770353a {
  margin-bottom: 28rpx;
}
.sec-title.data-v-f770353a {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  display: block;
}
.sec-text.data-v-f770353a {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}
.param-row.data-v-f770353a {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  font-size: 26rpx;
  gap: 16rpx;
}
.p-name.data-v-f770353a {
  color: var(--text-primary);
  font-weight: 500;
  min-width: 140rpx;
}
.p-type.data-v-f770353a {
  color: var(--color-primary);
  font-size: 22rpx;
  min-width: 80rpx;
}
.p-desc.data-v-f770353a {
  color: var(--text-secondary);
  flex: 1;
}
.example.data-v-f770353a {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
}
.ex-title.data-v-f770353a {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.ex-desc.data-v-f770353a {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin: 8rpx 0 16rpx;
  display: block;
}
.code-block.data-v-f770353a {
  margin-top: 12rpx;
  background: #1e1e1e;
  border-radius: 12rpx;
  overflow: auto;
  max-width: 100%;
}
.cb-header.data-v-f770353a {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 20rpx;
  background: #333;
}
.cb-lang.data-v-f770353a {
  font-size: 22rpx;
  color: #aaa;
}
.cb-copy.data-v-f770353a {
  font-size: 22rpx;
  color: #6cf;
}
.cb-content.data-v-f770353a {
  padding: 12rpx 20rpx 16rpx;
  font-size: 24rpx;
  color: #d4d4d4;
  white-space: pre;
  display: inline-block;
  min-width: 100%;
  box-sizing: border-box;
}
.related.data-v-f770353a {
  margin-top: 28rpx;
}
.tags.data-v-f770353a {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.tag.data-v-f770353a {
  font-size: 24rpx;
  color: var(--color-primary);
  background: #e8f4fd;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}
.ad-placeholder.data-v-f770353a {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: var(--bg-card);
  text-align: center;
  line-height: 100rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}