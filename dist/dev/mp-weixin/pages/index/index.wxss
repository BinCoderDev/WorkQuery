/* uni-app 全局 SCSS 变量 */
.login-container.data-v-83a5a03c {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 80rpx 48rpx 60rpx;
  background: var(--bg-primary);
}

/* 顶部 */
.header-area.data-v-83a5a03c {
  text-align: center;
  margin-bottom: 64rpx;
}
.logo-icon.data-v-83a5a03c {
  font-size: 80rpx;
  display: block;
  margin-bottom: 24rpx;
}
.app-name.data-v-83a5a03c {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 12rpx;
}
.app-desc.data-v-83a5a03c {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 功能介绍 */
.features.data-v-83a5a03c {
  width: 100%;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 60rpx;
  box-shadow: var(--shadow-sm);
}
.feature-item.data-v-83a5a03c {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.feature-item + .feature-item.data-v-83a5a03c {
  border-top: 1rpx solid var(--border-color);
}
.feature-icon.data-v-83a5a03c {
  font-size: 36rpx;
  margin-right: 20rpx;
}
.feature-text.data-v-83a5a03c {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 授权区域 */
.auth-area.data-v-83a5a03c {
  width: 100%;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.auth-step.data-v-83a5a03c {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 登录按钮 */
.login-btn.data-v-83a5a03c {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}
.login-btn.data-v-83a5a03c::after {
  border: none;
}
.login-btn-icon.data-v-83a5a03c {
  font-size: 40rpx;
  margin-right: 12rpx;
}
.login-btn-text.data-v-83a5a03c {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.auth-hint.data-v-83a5a03c {
  font-size: 24rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.6;
}
.auth-hint-sub.data-v-83a5a03c {
  font-size: 22rpx;
  color: var(--text-hint);
  opacity: 0.6;
  text-align: center;
  margin-top: 8rpx;
}

/* 资料完善 */
.step-title.data-v-83a5a03c {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 48rpx;
}
.profile-edit.data-v-83a5a03c {
  margin-bottom: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-pick-btn.data-v-83a5a03c {
  width: auto;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-pick-btn.data-v-83a5a03c::after {
  border: none;
}
.avatar-preview.data-v-83a5a03c {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--border-color);
  margin-bottom: 16rpx;
}
.avatar-empty.data-v-83a5a03c {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed var(--border-color);
  background: transparent;
}
.empty-icon.data-v-83a5a03c {
  font-size: 56rpx;
}
.avatar-hint.data-v-83a5a03c {
  font-size: 26rpx;
  color: var(--color-primary);
}
.nickname-edit.data-v-83a5a03c {
  width: 100%;
  margin-bottom: 48rpx;
}
.nickname-field.data-v-83a5a03c {
  width: 100%;
  height: 88rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: var(--text-primary);
  text-align: center;
  box-sizing: border-box;
}
.nickname-hint.data-v-83a5a03c {
  display: block;
  font-size: 22rpx;
  color: var(--text-hint);
  text-align: center;
  margin-top: 12rpx;
}
.enter-btn.data-v-83a5a03c {
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  border-radius: 44rpx;
  border: none;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.enter-btn.data-v-83a5a03c::after {
  border: none;
}
.skip-link.data-v-83a5a03c {
  font-size: 26rpx;
  color: var(--text-hint);
  text-decoration: underline;
}

/* 成功 */
.success-icon.data-v-83a5a03c {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.success-text.data-v-83a5a03c {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}
.success-sub.data-v-83a5a03c {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 底部 */
.footer.data-v-83a5a03c {
  margin-top: 40rpx;
}
.footer-text.data-v-83a5a03c {
  font-size: 22rpx;
  color: var(--text-hint);
  opacity: 0.5;
}