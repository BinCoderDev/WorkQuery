/* uni-app 全局 SCSS 变量 */
.container.data-v-9023ef44 {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* 用户信息区 */
.profile-section.data-v-9023ef44 {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx;
  background: var(--bg-card);
  border-radius: 16rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 32rpx;
}
.avatar-btn.data-v-9023ef44 {
  width: 120rpx;
  height: 120rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 1;
  flex-shrink: 0;
}
.avatar-btn.data-v-9023ef44::after {
  border: none;
}
.avatar.data-v-9023ef44 {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--border-color);
}
.avatar-placeholder.data-v-9023ef44 {
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-placeholder-icon.data-v-9023ef44 {
  font-size: 56rpx;
  line-height: 1;
}
.profile-info.data-v-9023ef44 {
  flex: 1;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.nickname-input.data-v-9023ef44 {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  height: 50rpx;
  line-height: 50rpx;
}
.profile-hint.data-v-9023ef44 {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 未登录提示 */
.profile-login-prompt.data-v-9023ef44 {
  position: relative;
}
.profile-login-title.data-v-9023ef44 {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}
.profile-login-btn.data-v-9023ef44 {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 32rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 30rpx;
  border: none;
}
.profile-login-btn.data-v-9023ef44::after {
  border: none;
}
