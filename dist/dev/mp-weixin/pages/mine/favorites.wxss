/* uni-app 全局 SCSS 变量 */
.container.data-v-ba0ad4ce {
  padding: 24rpx;
  padding-bottom: 140rpx;
}
.filter-tabs.data-v-ba0ad4ce {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 0 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  align-items: center;
}
.filter-tabs .active.data-v-ba0ad4ce {
  color: var(--color-primary);
  font-weight: 600;
}
.manage-btn.data-v-ba0ad4ce {
  margin-left: auto;
  color: var(--color-primary);
  font-size: 24rpx;
}
.empty.data-v-ba0ad4ce {
  text-align: center;
  padding: 120rpx 0;
}
.empty-icon.data-v-ba0ad4ce {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}
.empty-text.data-v-ba0ad4ce {
  font-size: 28rpx;
  color: var(--text-hint);
}
.fav-item.data-v-ba0ad4ce {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  gap: 16rpx;
}
.cb.data-v-ba0ad4ce {
  font-size: 36rpx;
  color: var(--text-hint);
}
.cb .checked.data-v-ba0ad4ce {
  color: var(--color-primary);
}
.item-content.data-v-ba0ad4ce {
  flex: 1;
}
.item-type-tag.data-v-ba0ad4ce {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 6rpx;
  background: #e8f0fe;
  color: var(--color-primary);
}
.item-title.data-v-ba0ad4ce {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.swipe-hint.data-v-ba0ad4ce {
  font-size: 28rpx;
  color: var(--text-hint);
  padding: 12rpx;
}
.batch-bar.data-v-ba0ad4ce {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: var(--bg-card);
  border-top: 1rpx solid var(--border-color);
}
.batch-btn.data-v-ba0ad4ce {
  background: var(--color-danger);
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
}