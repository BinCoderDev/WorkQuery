[
  {"knowledgeId":"excel_know_001","categoryId":"excel","categoryName":"Excel函数","title":"VLOOKUP 垂直查找","group":"查找与引用","definition":"最常用查找函数,在表格首列中垂直查找指定值,返回该行指定列的值。是面试必考。","syntax":"=VLOOKUP(查找值, 表格区域, 列序号, [匹配类型])","parameters":[{"name":"lookup_value","type":"any","desc":"要查找的值"},{"name":"table_array","type":"range","desc":"查找区域,首列必须包含查找值"},{"name":"col_index_num","type":"number","desc":"返回值所在列号(从1开始)"},{"name":"range_lookup","type":"boolean","desc":"FALSE=精确匹配,TRUE=近似匹配"}],"examples":[{"title":"精确查找员工姓名","description":"根据E2的ID在A:B区域查找姓名","code":"=VLOOKUP(E2, A2:B10, 2, FALSE)","codeHtml":"<span style=\"color:#569CD6\">=VLOOKUP</span>(E2, A2:B10, 2, FALSE)"}],"tags":["查找","函数","必考"],"usageFrequency":98},
  {"knowledgeId":"excel_know_002","categoryId":"excel","categoryName":"Excel函数","title":"SUMIF/SUMIFS 条件求和","group":"数学与统计","definition":"SUMIF单条件区域求和。SUMIFS支持多个条件同时筛选求和,参数顺序与SUMIF不同。","syntax":"=SUMIF(条件区域, 条件, [求和区域])\n=SUMIFS(求和区域, 条件区域1, 条件1, ...)","parameters":[],"examples":[{"title":"单条件求和","description":"销售额>1000的总和","code":"=SUMIF(B2:B20, \">1000\")","codeHtml":"<span style=\"color:#569CD6\">=SUMIF</span>(B2:B20, \">1000\")"},{"title":"多条件求和","description":"北京地区且>1000","code":"=SUMIFS(C2:C20, A2:A20, \"北京\", C2:C20, \">1000\")","codeHtml":"<span style=\"color:#569CD6\">=SUMIFS</span>(C2:C20, A2:A20, \"北京\", C2:C20, \">1000\")"}],"tags":["求和","条件","必考"],"usageFrequency":92},
  {"knowledgeId":"excel_know_003","categoryId":"excel","categoryName":"Excel函数","title":"IF 逻辑判断与嵌套","group":"逻辑","definition":"IF根据条件判断返回不同值。可嵌套实现多条件分支(如成绩等级)。Excel 2016+可用IFS替代多层嵌套。","syntax":"=IF(条件, 条件为真返回值, 条件为假返回值)","parameters":[],"examples":[{"title":"成绩及格判断","description":">=60显示及格","code":"=IF(B2>=60, \"及格\", \"不及格\")","codeHtml":"<span style=\"color:#569CD6\">=IF</span>(B2>=60, \"及格\", \"不及格\")"},{"title":"嵌套多等级","description":"优/良/中/差四级","code":"=IF(B2>=90,\"优\",IF(B2>=75,\"良\",IF(B2>=60,\"中\",\"差\")))","codeHtml":"<span style=\"color:#569CD6\">=IF</span>(B2>=90,\"优\",<span style=\"color:#569CD6\">IF</span>(B2>=75,\"良\",<span style=\"color:#569CD6\">IF</span>(B2>=60,\"中\",\"差\")))"}],"tags":["逻辑","条件","必考"],"usageFrequency":95},
  {"knowledgeId":"excel_know_004","categoryId":"excel","categoryName":"Excel函数","title":"COUNT/COUNTA/COUNTIF 计数","group":"数学与统计","definition":"COUNT统计数字个数。COUNTA统计非空单元格。COUNTIF按条件计数。COUNTIFS多条件计数。","syntax":"=COUNTIF(区域, 条件)","parameters":[],"examples":[{"title":"统计及格人数","description":">=60的人数","code":"=COUNTIF(B2:B50, \">=60\")","codeHtml":"<span style=\"color:#569CD6\">=COUNTIF</span>(B2:B50, \">=60\")"}],"tags":["计数","统计","常用"],"usageFrequency":85},
  {"knowledgeId":"excel_know_005","categoryId":"excel","categoryName":"Excel函数","title":"文本函数 LEFT/RIGHT/MID/CONCAT/TRIM","group":"文本","definition":"文本截取(LEFT/RIGHT/MID)、合并(CONCATENATE/&)、清理(TRIM)、长度(LEN)、替换(REPLACE/SUBSTITUTE)。","syntax":"=LEFT(text, num_chars)\n=RIGHT(text, num_chars)\n=MID(text, start, num_chars)\n=TRIM(text)","parameters":[],"examples":[{"title":"合并姓和名","description":"用&和空格连接","code":"=A1 & \" \" & B1","codeHtml":"=A1 &amp; \" \" &amp; B1"},{"title":"提取前5个字符","description":"LEFT截取","code":"=LEFT(A1, 5)","codeHtml":"<span style=\"color:#569CD6\">=LEFT</span>(A1, 5)"}],"tags":["文本","字符串","常用"],"usageFrequency":88},
  {"knowledgeId":"excel_know_006","categoryId":"excel","categoryName":"Excel函数","title":"单元格引用 相对/绝对/混合","group":"基础概念","definition":"A1相对引用(拖动变化)。$A$1绝对引用(固定不变)。$A1列绝对行相对。A$1列相对行绝对。按F4快速切换。","syntax":"$A$1(绝对) / A1(相对) / $A1(列固定) / A$1(行固定)","parameters":[],"examples":[{"title":"混合引用","description":"列固定B,行相对","code":"=$B1 * A$1","codeHtml":"=<span style=\"color:#569CD6\">$B1</span> * <span style=\"color:#569CD6\">A$1</span>"}],"tags":["引用","基础","必考"],"usageFrequency":90},
  {"knowledgeId":"excel_know_007","categoryId":"excel","categoryName":"Excel函数","title":"数据透视表","group":"数据分析","definition":"Excel最强大的数据分析工具,无需公式即可快速分类汇总、交叉分析、排序筛选。拖拽字段到行/列/值/筛选区域完成多维分析。","syntax":"插入 → 数据透视表","parameters":[],"examples":[{"title":"按部门汇总销售额","description":"行=部门,值=销售额求和","code":"拖拽\"部门\"到行区域,\"销售额\"到值区域","codeHtml":"拖拽字段即可完成分析,无需编写公式"}],"tags":["数据分析","汇总","高级"],"usageFrequency":75},
  {"knowledgeId":"excel_know_008","categoryId":"excel","categoryName":"Excel函数","title":"ROUND/ROUNDUP/ROUNDDOWN 舍入","group":"数学与统计","definition":"ROUND四舍五入到指定小数位。ROUNDUP向上舍入(远离0)。ROUNDDOWN向下舍入(靠近0)。INT截断取整。","syntax":"=ROUND(number, num_digits)","parameters":[],"examples":[{"title":"保留两位小数","description":"四舍五入到2位","code":"=ROUND(3.14159, 2) → 3.14","codeHtml":"<span style=\"color:#569CD6\">=ROUND</span>(3.14159, 2) → 3.14"}],"tags":["数学","舍入","常用"],"usageFrequency":72},
  {"knowledgeId":"excel_know_009","categoryId":"excel","categoryName":"Excel函数","title":"日期时间函数 TODAY/NOW/YEAR/MONTH/DAY","group":"日期时间","definition":"TODAY()当前日期,NOW()当前日期时间。YEAR/MONTH/DAY提取日期部分。DATEDIF计算日期间隔。NETWORKDAYS计算工作日。","syntax":"=TODAY()  /  =YEAR(date)  /  =DATEDIF(d1,d2,\"Y\")","parameters":[],"examples":[{"title":"计算工龄","description":"DATEDIF计算年份差","code":"=DATEDIF(B2, TODAY(), \"Y\")","codeHtml":"<span style=\"color:#569CD6\">=DATEDIF</span>(B2, TODAY(), \"Y\")"},{"title":"计算工作日","description":"排除周末的天数","code":"=NETWORKDAYS(A1, B1)","codeHtml":"<span style=\"color:#569CD6\">=NETWORKDAYS</span>(A1, B1)"}],"tags":["日期","时间","常用"],"usageFrequency":80},
  {"knowledgeId":"excel_know_010","categoryId":"excel","categoryName":"Excel函数","title":"逻辑函数 AND/OR/NOT/IFERROR","group":"逻辑","definition":"AND(全真才真),OR(有真即真),NOT(取反)。IFERROR捕获错误返回备用值。IFNA只捕获#N/A。XOR异或。","syntax":"=AND(c1,c2,...)  /  =IFERROR(formula, fallback)","parameters":[],"examples":[{"title":"多条件判断","description":"两科都及格","code":"=AND(B2>=60, C2>=60)","codeHtml":"<span style=\"color:#569CD6\">=AND</span>(B2>=60, C2>=60)"},{"title":"错误处理","description":"除零时返回0","code":"=IFERROR(A1/B1, 0)","codeHtml":"<span style=\"color:#569CD6\">=IFERROR</span>(A1/B1, 0)"}],"tags":["逻辑","错误处理","常用"],"usageFrequency":78},
  {"knowledgeId":"excel_know_011","categoryId":"excel","categoryName":"Excel函数","title":"INDEX+MATCH 高级查找","group":"查找与引用","definition":"INDEX+MATCH组合可反向查找(从右向左),比VLOOKUP更灵活。插入删除列时引用不会错位。","syntax":"=INDEX(返回列, MATCH(查找值, 查找列, 0))","parameters":[],"examples":[{"title":"反向查找","description":"根据姓名查ID(从右向左)","code":"=INDEX(A:A, MATCH(\"张三\", B:B, 0))","codeHtml":"<span style=\"color:#569CD6\">=INDEX</span>(A:A, <span style=\"color:#569CD6\">MATCH</span>(\"张三\", B:B, 0))"}],"tags":["查找","高级","必考"],"usageFrequency":85},
  {"knowledgeId":"excel_know_012","categoryId":"excel","categoryName":"Excel函数","title":"条件格式与数据验证","group":"数据工具","definition":"条件格式根据值自动应用颜色/数据条/图标集。数据验证限制单元格输入类型和范围(整数/列表/日期等)。","syntax":"开始 → 条件格式  /  数据 → 数据验证","parameters":[],"examples":[{"title":"高亮重复值","description":"条件格式标记重复数据","code":"开始→条件格式→突出显示→重复值","codeHtml":"菜单: 开始→条件格式→突出显示单元格规则→重复值"},{"title":"创建下拉列表","description":"限制输入为选项列表","code":"数据→数据验证→允许:序列→来源:选项1,选项2","codeHtml":"数据→数据验证→序列"}],"tags":["条件格式","数据验证","常用"],"usageFrequency":75}
]
